# PostgreSQL (Prisma migrations and runtime)
# https://www.prisma.io/docs/orm/reference/connection-urls
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/circacal?schema=public"

# Better Auth — encryption and callback base URL
# Secret: openssl rand -base64 32 (minimum 32 characters)
BETTER_AUTH_SECRET="development-only-replace-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:5173"

# Origin for links in outbound email (verification). If unset, defaults to http://localhost:3000
# Use the same URL users open in the browser (match BETTER_AUTH_URL in most setups).
BASE_URL="http://localhost:5173"
